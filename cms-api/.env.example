# Cafinity CMS API configuration

DJANGO_ENV=prod
DJANGO_DEBUG=false
LOG_LEVEL=INFO
TIME_ZONE=Asia/Kolkata

# Security
SECRET_KEY=<set-strong-django-secret>
JWT_SECRET_KEY=<set-strong-jwt-secret>
SECURE_SSL_REDIRECT=true
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true
ENABLE_HSTS=true
USE_X_FORWARDED_PROTO=true
DJANGO_ADMIN_URL=secret-management-path/
ADMIN_ALLOWED_IPS=127.0.0.1

# Network and CORS
ALLOWED_HOSTS=cms-api.atpl.corp,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=https://cms.atpl.corp,http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=https://cms.atpl.corp,https://cms-api.atpl.corp
API_CONNECT_ORIGIN=https://cms-api.atpl.corp
COMPANY_DOMAIN=https://cms.atpl.corp
FRONTEND_URL=https://cms.atpl.corp

# Database
DB_NAME=cms_db
DB_USER=dbadmin
DB_PASSWORD=<set-db-password>
DB_HOST=127.0.0.1
DB_PORT=5432

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=<set-smtp-user>
EMAIL_HOST_PASSWORD=<set-smtp-app-password>
DEFAULT_FROM_EMAIL=Cafinity <no-reply@your-company-domain.example>
EMAIL_REPLY_TO=support@your-company-domain.example
EMPLOYEE_LOGIN_URL=https://cms.atpl.corp/login
EMPLOYEE_PASSWORD_RESET_TTL_SECONDS=86400
EMAIL_AMPCUS_LOGO_URL=https://cms.atpl.corp/static/emails/ampcus-tech-logo.png
EMAIL_CAFINITY_LOGO_URL=https://cms.atpl.corp/static/emails/cafinity-logo.png
EMAIL_SUPPORT_TEAM_NAME=PRAKVI TECHNO SOLUTIONS PVT LTD HR Team
EMAIL_COPYRIGHT_LINE=Copyright 2009-2026 CAFINITY Corporation Pvt. Ltd.

# Email recipients
ADMIN_EMAIL=admin@your-company-domain.example
REPORT_EMAIL=reports@your-company-domain.example
