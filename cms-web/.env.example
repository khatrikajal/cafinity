# ============================================================================
# Cafinity rebrand — logo + favicon update
# Cafinity Frontend Configuration (Template)
# ============================================================================
# Copy this file to .env and fill real values.
# Never commit real .env files with secrets.
# ============================================================================

# ============================================================================
# API CONFIGURATION
# ============================================================================

# Browser API base (used by src/api/client.ts)
VITE_API_BASE_URL=https://cms-api.atpl.corp/api/v1

# Optional alias for tools that read VITE_API_URL
VITE_API_URL=https://cms-api.atpl.corp/api/v1
VITE_API_TIMEOUT=30000

# Dev proxy target (used by vite.config.ts)
VITE_PROXY_TARGET=http://127.0.0.1:8000
BACKEND_URL=http://127.0.0.1:8000

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

VITE_APP_NAME=Cafinity
VITE_APP_VERSION=1.0.0
VITE_ENVIRONMENT=production

# ============================================================================
# FEATURE FLAGS
# ============================================================================

VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_ERROR_LOGGING=false
VITE_ENABLE_PERFORMANCE_MONITORING=false

# ============================================================================
# UI CONFIGURATION
# ============================================================================

VITE_LOCALE=en-US
VITE_TIMEZONE=Asia/Kolkata
VITE_DATE_FORMAT=DD/MM/YYYY
VITE_TIME_FORMAT=HH:mm:ss

# ============================================================================
# POLLING & REFRESH INTERVALS (ms)
# ============================================================================

VITE_POLL_INTERVAL=30000

# ============================================================================
# DEBUGGING
# ============================================================================

VITE_DEBUG_MODE=false
VITE_LOG_LEVEL=info
